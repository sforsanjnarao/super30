generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}
//i am connection user to workflow and Credentials with one to many relationship with email not id
model User{
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  userName      String?
  //one to many relation
  Workflows Workflow[] 
  Credentials Credentials[]
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Workflow{ //this like a workflow
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    name          String  @unique
    author        User      @relation(fields: [authorId],references: [id])
    authorId      String    @db.ObjectId
    webhookUrl     String?   @unique   //basically a url or we can it webhookUrl
    active        Boolean   @default(false)
    nodes         Json[]
    connections   Json[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

}


generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}
//i am connection user to workflow and credintials with one to many relationship with email not id
model User{
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  userName      String?
  //one to many relation
  Workflows Workflow[] 
  Credentials CredentialsEntity[]
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Workflow{
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    name          String  @unique
    
    author        User      @relation(fields: [authorId],references: [id])
    authorId      String    @db.ObjectId
    webhookUrl     String?   @unique   //basically a url or we can it webhookUrl
    active        Boolean   @default(false)
    nodes         Json[]
    connections   Json[]
    settings      String
    staticData    String
    TriggerCount  Int  @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

}


model CredentialsEntity{
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String? 

  author        User    @relation(fields: [authorId],references: [id])
  authorId    String   @db.ObjectId
  data   Json
  type   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
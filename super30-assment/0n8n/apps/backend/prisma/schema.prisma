generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}
//i am connection user to workflow and Credentials with one to many relationship with email not id
model User{
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  userName      String?
  //one to many relation
  Workflows Workflow[] 
  Credentials Credentials[]
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Workflow{ //this like a workflow
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    name          String  @unique
    author        User      @relation(fields: [authorId],references: [id])
    authorId      String    @db.ObjectId
    webhookId     String?   @unique   //basically a url or we can it webhookUrl
    active        Boolean   @default(false)
    nodes         Json[]
    connections   Json[]
    executions   Execution[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

}


model Execution {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  workflow    Workflow  @relation(fields: [workflowId], references: [id])
  workflowId  String    @db.ObjectId
  status      String    // e.g., "running", "completed", "failed"
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  data        Json?     // To store the initial data that started the workflow
  error       Json?     // To store any error information if the execution failed
  ExecutionLog  ExecutionLog[]

}


model ExecutionLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  execution   Execution @relation(fields: [executionId], references: [id])
  executionId String    @db.ObjectId
  nodeId      String    // The unique ID of the node from your workflow's `nodes` JSON
  nodeType    String
  nodeName    String
  inputData   Json?
  outputData  Json?
  status      String    // e.g., "success", "error"
  executedAt  DateTime  @default(now())
}


model Credentials{
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String? 

  author        User    @relation(fields: [authorId],references: [id])
  authorId    String   @db.ObjectId
  data   Json
  type   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



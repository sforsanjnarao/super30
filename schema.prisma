generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String
  password String
  workflow  Workflow[]
}

model Workflow {
  id        String   @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references:[id])


  triggerId String
  // One-to-one trigger
  trigger   Trigger?
  //One-to-many relationships
  action Action[]
  execution Execution[]
}
//comes in to node section
model Trigger {
  id        String             @id @default(uuid())
  workflowId     String             @unique
  workflow       Workflow               @relation(fields: [workflowId], references: [id])
  triggerId String
  type      AvailableTriggers  @relation(fields: [triggerId], references: [id])
}

model AvailableTriggers {
  id       String    @id @default(uuid())
  name     String
  triggers Trigger[]
}

// we are storing available nodes in frontend but here we are doing in in backend 
model Action {
    id        String             @id @default(uuid())
    workflowId     String             @unique
    workflow      Workflow               @relation(fields: [workflowId], references: [id])
    actionId  String
    type      AvailableAction    @relation(fields: [actionId], references: [id])   
}

model AvailableAction{
     id        String             @id @default(uuid())
     name      String              
     action    Action[]
}





model Execution {
  id             String         @id @default(uuid())
  workflowId          String
  workflow            Workflow            @relation(fields: [workflowId], references: [id])
  metadata       Json
  executionOutbox   ExecutionOutbox?
}

model ExecutionOutbox {
  id        String  @id @default(uuid())
  executionId  String  @unique
  execution   Execution  @relation(fields: [executionId], references: [id])
}